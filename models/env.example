# MongoDB Connection String (REQUIRED - Get this from MongoDB Atlas or Render.com MongoDB add-on)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/pos_bms?retryWrites=true&w=majority

# Secret key for encrypting session cookies (Generate a random string)
SESSION_SECRET=your_super_secret_session_key_change_this

# Server Port (Render.com sets this automatically, default locally is 3000)
PORT=3000

# Node Environment (development or production)
NODE_ENV=development

# Email Configuration (For Forgot Password, Invoices, Alerts via Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Base URL of your application (Used for generating email links)
BASE_URL=http://localhost:3000
