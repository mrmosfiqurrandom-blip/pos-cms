<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | POS-BMS</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="auth-container">
        <div class="auth-card">
            <h2>POS-BMS Login</h2>
            <p style="text-align:center; margin-bottom:20px; color:#6b7280; font-size:14px;">লগইন করুন</p>
            
            <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <% if (success_msg) { %>
                <div class="alert alert-success"><%= success_msg %></div>
            <% } %>

            <form action="/login" method="POST" novalidate>
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="owner@example.com" required autofocus>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="Enter password" required minlength="6">
                </div>
                
                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">
                    Login / লগইন
                </button>
            </form>
            
            <p style="text-align:center; margin-top:20px; font-size:14px;">
                Don't have an account? <a href="/signup">Sign Up / নিবন্ধন করুন</a>
            </p>
        </div>
    </div>

</body>
</html>
