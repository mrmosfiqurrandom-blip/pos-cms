<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Business Sign Up | POS-BMS</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="auth-container">
        <div class="auth-card">
            <h2>Register Business</h2>
            <p style="text-align:center; margin-bottom:20px; color:#6b7280; font-size:14px;">নতুন ব্যবসায় নিবন্ধন করুন</p>
            
            <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/signup" method="POST" novalidate>
                <div class="form-group">
                    <label class="form-label">Business Name / ব্যবসার নাম</label>
                    <input type="text" name="businessName" class="form-control" placeholder="e.g. ABC General Store" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Owner Name / মালিকের নাম</label>
